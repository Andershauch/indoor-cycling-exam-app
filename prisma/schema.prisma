generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AdminRole {
  SUPER_ADMIN
  EDITOR
}

enum InvitationChannel {
  EMAIL
  SMS
}

enum InvitationStatus {
  CREATED
  SENT
  OPENED
  COMPLETED
  EXPIRED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
  EXPIRED
}

enum ExamSessionStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model AdminUser {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  role           AdminRole    @default(EDITOR)
  isActive       Boolean      @default(true)
  lastMagicLinkSentAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdExams   ExamSet[]
  examSessions   ExamSession[]
  createdInvites Invitation[]
  magicLinkTokens AdminMagicLinkToken[]
  auditLogs      AdminAuditLog[]
}

model AdminMagicLinkToken {
  id          String    @id @default(cuid())
  adminUserId String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, expiresAt])
}

model AdminAuditLog {
  id          String     @id @default(cuid())
  adminUserId String?
  action      String
  targetType  String?
  targetId    String?
  targetLabel String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime   @default(now())
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

model AdminMagicLinkRequest {
  id        String   @id @default(cuid())
  email     String
  ipAddress String?
  userAgent String?
  outcome   String
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@index([outcome, createdAt])
}

model ExamSet {
  id               String              @id @default(cuid())
  slug             String              @unique
  title            String
  description      String?
  version          Int                 @default(1)
  timeLimitMinutes Int
  passPercentage   Int
  isActive         Boolean             @default(false)
  publishedAt      DateTime?
  importedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  createdByAdminId String?
  createdByAdmin   AdminUser?          @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)
  examQuestions    ExamQuestion[]
  examSessions     ExamSession[]
  invitations      Invitation[]
  attempts         ParticipantAttempt[]

  @@index([isActive])
}

model ExamSession {
  id               String            @id @default(cuid())
  examSetId        String
  createdByAdminId String?
  title            String
  location         String?
  status           ExamSessionStatus @default(DRAFT)
  startsAt         DateTime?
  closedAt         DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  examSet          ExamSet           @relation(fields: [examSetId], references: [id], onDelete: Restrict)
  createdByAdmin   AdminUser?        @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)
  invitations      Invitation[]
  attempts         ParticipantAttempt[]

  @@index([examSetId, status])
  @@index([createdByAdminId, createdAt])
}

model Question {
  id              String         @id @default(cuid())
  externalKey     String         @unique
  category        String?
  questionText    String
  explanation     String?
  sourceReference String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  options         AnswerOption[]
  examEntries     ExamQuestion[]
}

model ExamQuestion {
  id         String          @id @default(cuid())
  examSetId  String
  questionId String
  /// Fast rækkefølge for hele prøven.
  position   Int
  createdAt  DateTime        @default(now())
  examSet    ExamSet         @relation(fields: [examSetId], references: [id], onDelete: Cascade)
  question   Question        @relation(fields: [questionId], references: [id], onDelete: Restrict)
  answers    AttemptAnswer[]

  @@unique([examSetId, position])
  @@unique([examSetId, questionId])
  @@index([questionId])
}

model AnswerOption {
  id         String          @id @default(cuid())
  questionId String
  label      String
  optionText String
  isCorrect  Boolean         @default(false)
  sortOrder  Int
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  question   Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedIn AttemptAnswer[]

  @@unique([questionId, label])
  @@unique([questionId, sortOrder])
  @@index([questionId, isCorrect])
}

model Invitation {
  id                String             @id @default(cuid())
  examSetId         String
  examSessionId     String?
  createdByAdminId  String?
  channel           InvitationChannel
  status            InvitationStatus   @default(CREATED)
  token             String             @unique
  participantSessionNonceHash String?
  participantSessionExpiresAt DateTime?
  recipientName     String?
  recipientEmail    String?
  recipientPhone    String?
  deliveryReference String?
  lastDeliveryError String?
  sentAt            DateTime?
  openedAt          DateTime?
  completedAt       DateTime?
  expiresAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  examSet           ExamSet            @relation(fields: [examSetId], references: [id], onDelete: Cascade)
  examSession       ExamSession?       @relation(fields: [examSessionId], references: [id], onDelete: SetNull)
  createdByAdmin    AdminUser?         @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)
  attempts          ParticipantAttempt[]

  @@index([examSetId, status])
  @@index([examSessionId, status])
  @@index([channel, status])
}

model ParticipantAttempt {
  id                   String             @id @default(cuid())
  examSetId            String
  examSessionId        String?
  invitationId         String?
  status               AttemptStatus      @default(IN_PROGRESS)
  participantName      String?
  participantEmail     String?
  participantPhone     String?
  startedAt            DateTime           @default(now())
  lastSavedAt          DateTime?
  submittedAt          DateTime?
  expiresAt            DateTime?
  currentQuestionIndex Int?
  correctAnswerCount   Int?
  totalQuestionCount   Int?
  scorePercentage      Decimal?           @db.Decimal(5, 2)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  examSet              ExamSet            @relation(fields: [examSetId], references: [id], onDelete: Restrict)
  examSession          ExamSession?       @relation(fields: [examSessionId], references: [id], onDelete: SetNull)
  invitation           Invitation?        @relation(fields: [invitationId], references: [id], onDelete: SetNull)
  answers              AttemptAnswer[]

  @@index([examSetId, status])
  @@index([examSessionId, status])
  @@index([submittedAt])
}

model AttemptAnswer {
  id               String             @id @default(cuid())
  attemptId        String
  examQuestionId   String
  selectedOptionId String?
  /// Snapshot gør rapportering stabil ved aflevering.
  isCorrect        Boolean?
  answeredAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  attempt          ParticipantAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  examQuestion     ExamQuestion       @relation(fields: [examQuestionId], references: [id], onDelete: Restrict)
  selectedOption   AnswerOption?      @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([attemptId, examQuestionId])
  @@index([selectedOptionId])
  @@index([examQuestionId])
}
